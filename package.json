{
  "name": "ai4gc-lab-website",
  "version": "1.0.0",
  "private": true,
  "description": "AI4GC Lab research group website",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "dev:proxy": "NODE_ENV=development NODE_USE_ENV_PROXY=1 next dev --webpack",
    "build": "next build --webpack",
    "build:proxy": "NODE_USE_ENV_PROXY=1 next build --webpack",
    "dev:turbopack": "next dev --turbopack",
    "start": "next start",
    "build:turbopack": "next build --turbopack",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "pubs:sync": "node scripts/sync-dblp.mjs",
    "team:order": "node scripts/gen-member-order.mjs",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@retorquere/bibtex-parser": "^10.0.0",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "katex": "^0.17.0",
    "lucide-react": "^1.6.0",
    "mdast-util-to-string": "^4.0.0",
    "motion": "^12.40.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "unist-util-visit": "^5.1.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
