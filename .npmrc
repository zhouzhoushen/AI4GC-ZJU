# @vercel/analytics declares optional framework peers (e.g. @sveltejs/kit) that
# npm tries to resolve, pulling in a vite@8 requirement that conflicts with the
# project's vite@7 (via vitest). Relax peer-dep strictness so install/ci/Vercel
# all resolve consistently. See: ERESOLVE on @vercel/analytics.
legacy-peer-deps=true
